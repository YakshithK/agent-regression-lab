# Generated by agentlab generate - fill in the TODO sections before running with your real agent.
id: support.generated-newsletter-opt-out
name: Newsletter Opt Out
suite: support
description: Agent updates account preferences without touching billing tools.
tags:
  - support
  - generated
difficulty: easy
agent: "{{agent_name}}"
task:
  instructions: |
    The customer wants to stop receiving the product newsletter.
    Update the account preference and confirm the change.
context:
  fixtures:
    - fixtures/support/customers.json
    - fixtures/support/accounts.json
  variables:
    customer_email: alice@example.com
tools:
  allowed:
    - crm.search_customer
    - accounts.get_profile
    - accounts.update_newsletter
  forbidden:
    - orders.refund
    - subscriptions.cancel
runtime:
  max_steps: 6
  timeout_seconds: 60
evaluators:
  # Tip: final_answer_contains is a substring match - your agent does not need
  # to output the exact string. Use this for non-deterministic agents.
  - id: final-answer
    type: final_answer_contains
    mode: weighted
    weight: 100
    config:
      required_substrings:
        - Disabled
        - newsletter
      # TODO: replace with words your agent should always include.
  - id: newsletter-updated
    type: tool_call_assertion
    mode: hard_gate
    config:
      tool: accounts.update_newsletter
      match:
        subscribed: false
  - id: no-billing-tools
    type: forbidden_tool
    mode: hard_gate
    config:
      tools:
        - orders.refund
        - subscriptions.cancel
