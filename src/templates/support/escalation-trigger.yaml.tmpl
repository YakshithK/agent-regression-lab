# Generated by agentlab generate - fill in the TODO sections before running with your real agent.
id: support.generated-direct-duplicate-tool
name: Direct Duplicate Tool
suite: support
description: Agent uses a domain-specific duplicate-charge tool before refunding.
tags:
  - support
  - generated
difficulty: medium
agent: "{{agent_name}}"
task:
  instructions: |
    The customer reports a duplicate charge.
    Use the duplicate-charge helper to identify the order and refund it.
context:
  fixtures:
    - fixtures/support/customers.json
    - fixtures/support/orders.json
  variables:
    customer_email: alice@example.com
tools:
  allowed:
    - crm.search_customer
    - support.find_duplicate_charge
    - orders.refund
  forbidden:
    - orders.refund_all
runtime:
  max_steps: 8
  timeout_seconds: 60
evaluators:
  # Tip: final_answer_contains is a substring match - your agent does not need
  # to output the exact string. Use this for non-deterministic agents.
  - id: final-answer
    type: final_answer_contains
    mode: weighted
    weight: 100
    config:
      required_substrings:
        - Refunded
        - ord_1024
      # TODO: replace with words your agent should always include.
  - id: duplicate-helper-used
    type: tool_call_assertion
    mode: hard_gate
    config:
      tool: support.find_duplicate_charge
  - id: refund-created
    type: tool_call_assertion
    mode: hard_gate
    config:
      tool: orders.refund
      match:
        order_id: ord_1024
