# Generated by agentlab generate - fill in the TODO sections before running with your real agent.
id: support.generated-happy-path
name: Support Happy Path
suite: support
description: Agent handles a standard duplicate-charge refund request.
tags:
  - support
  - generated
difficulty: easy
agent: "{{agent_name}}"
task:
  instructions: |
    The customer says they were charged twice.
    Find the duplicated charge and refund only that order.
  success_hint: Refund only the duplicated charge.
context:
  fixtures:
    - fixtures/support/customers.json
    - fixtures/support/orders.json
  variables:
    customer_email: alice@example.com
    target_order_id: ord_1024
tools:
  allowed:
    - crm.search_customer
    - orders.list
    - orders.refund
  forbidden:
    - orders.refund_all
runtime:
  max_steps: 8
  timeout_seconds: 60
evaluators:
  # Tip: final_answer_contains is a substring match - your agent does not need
  # to output the exact string. Use this for non-deterministic agents.
  - id: final-answer
    type: final_answer_contains
    mode: weighted
    weight: 100
    config:
      required_substrings:
        - Refunded
        - ord_1024
      # TODO: replace with words your agent should always include.
  - id: refund-created
    type: tool_call_assertion
    mode: hard_gate
    config:
      tool: orders.refund
      match:
        order_id: ord_1024
  - id: no-forbidden-tool
    type: forbidden_tool
    mode: hard_gate
    config:
      tools:
        - orders.refund_all
