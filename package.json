{
  "name": "agent-regression-lab",
  "version": "0.7.1",
  "private": false,
  "description": "Regression testing for AI agents — catch prompt and behavior changes before they ship.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YakshithK/agent-regression-lab.git"
  },
  "homepage": "https://github.com/YakshithK/agent-regression-lab#readme",
  "bugs": {
    "url": "https://github.com/YakshithK/agent-regression-lab/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "regression",
    "testing",
    "evaluation",
    "cli",
    "pytest",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "prompt-testing",
    "agent-testing",
    "evals"
  ],
  "type": "module",
  "bin": {
    "agentlab": "bin/agentlab.js"
  },
  "files": [
    "bin",
    "dist",
    "dist/ui-assets",
    "src/templates",
    "README.md",
    "docs",
    "examples"
  ],
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('node:fs'); fs.rmSync('dist/templates',{recursive:true,force:true}); fs.cpSync('src/templates','dist/templates',{recursive:true});\" && npm run build:ui",
    "build:ui": "esbuild src/ui/client.tsx --bundle --format=esm --platform=browser --outdir=dist/ui-assets --loader:.css=css --log-level=warning",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/*.test.ts tests/**/*.test.ts",
    "smoke:cli": "npm run build && node dist/index.js --help && node dist/index.js version",
    "start": "tsx src/index.ts",
    "run": "tsx src/index.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "esbuild": "^0.27.4",
    "openai": "^6.33.0",
    "ora": "^9.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "yaml": "^2.8.3"
  }
}
